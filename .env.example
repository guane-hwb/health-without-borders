# ==========================================
# Health Without Borders - Environment Template
# ==========================================
# INSTRUCTIONS: Copy this file to '.env' and replace the values.
# DO NOT commit the actual '.env' file to version control.

# --- Application Setup ---
PROJECT_NAME="Health Without Borders API (Local)"
API_V1_STR="/api/v1"
DEBUG=True

# --- Security ---
# Generate a secure key in production using: openssl rand -hex 32
SECRET_KEY="super_secret_development_key_change_me_in_production"
ALGORITHM="HS256"
# 1440 minutes = 24 hours. (Production usually requires 30 days for offline support)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Initial SuperAdmin Bootstrap (Required for scripts/create_generic_user.py) ---
FIRST_SUPERUSER_EMAIL="admin@example.org"
FIRST_SUPERUSER_PASSWORD="change_me_now"

# --- API Perimeter Security ---
# Comma-separated list. Keep empty in local dev if needed.
BACKEND_CORS_ORIGINS="https://app.example.org,https://staging.example.org"
RATE_LIMIT_LOGIN="10/minute"
RATE_LIMIT_PATIENT_SEARCH="30/minute"

# --- Database Connection (Local Docker) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL="postgresql://postgres:password@localhost:5432/hwb_local"

# --- Backend Selection (Vendor-Neutral Deployment) ---
# Controls which concrete implementation is used for the FHIR Store and LLM.
# This makes the project deployable outside GCP (AWS, Azure, HAPI FHIR, OpenAI, etc.).
FHIR_BACKEND="gcp"   # Options: "gcp", "noop"
LLM_BACKEND="gemini" # Options: "gemini", "noop"

# --- Google Cloud Platform (Optional for local dev without FHIR RDA) ---
GCP_PROJECT_ID="your-gcp-project-id"
GCP_LOCATION="your-gcp-region"  # e.g., "us-central1"
GCP_DATASET_ID="your-fhir-dataset"
GCP_FHIR_STORE_ID="your-fhir-store"

# Path to your local GCP service account key (Required only if testing GCP services locally)
# GOOGLE_APPLICATION_CREDENTIALS="./gcp_key.json"

LLM_MODEL_NAME="gemini-2.5-pro"